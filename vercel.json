{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/htmls", "destination": "/", "permanent": false },
    { "source": "/htmls/:path*", "destination": "/:path*", "permanent": false }
  ],
  "rewrites": [
    { "source": "/", "destination": "/htmls/index.html" },
    { "source": "/:path*", "destination": "/htmls/:path*" }
  ]
}
